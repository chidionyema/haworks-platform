{{- /* Vault Agent template: renders DB credentials as JSON for AgentFile mode.
       SERVICE_ROLE must be replaced per-service (e.g., haworks-orders).
       The app reads /vault/secrets/db-{service}.json via UsePeriodicPasswordProvider. */ -}}
{{ with secret "database/static-creds/SERVICE_ROLE" }}
{
  "username": "{{ .Data.username }}",
  "password": "{{ .Data.password }}"
}
{{ end }}
